# ---------------------------------------------------------------------------
# sempkg-agent configuration (copy to .env and adjust)
# ---------------------------------------------------------------------------

# --- LLM backend (OpenAI-compatible; OpenRouter by default) ---
# Your OpenRouter API key. Also used by the sempkg reranker subprocess.
OPENROUTER_API_KEY=sk-or-...

# Fully configurable model — any slug your api_base serves.
SEMPKG_AGENT_MODEL=anthropic/claude-3.5-sonnet
SEMPKG_AGENT_API_BASE=https://openrouter.ai/api/v1
SEMPKG_AGENT_TEMPERATURE=0.0
SEMPKG_AGENT_MAX_TOKENS=4096
SEMPKG_AGENT_REQUEST_TIMEOUT=120
SEMPKG_AGENT_MAX_RETRIES=3

# --- sempkg MCP retrieval backend ---
# Path to the workspace containing sempkg.toml and installed bundles.
SEMPKG_AGENT_MCP_WORKSPACE=.
# Executable that launches the sempkg MCP server (must be on PATH).
SEMPKG_AGENT_MCP_COMMAND=sempkg
# Comma-separated tool allowlist (empty = expose all sempkg tools).
# SEMPKG_AGENT_MCP_ALLOWED_TOOLS=query,list_packages,list_files,read_code,read_docs,read_symbol,get_callers,get_callees,get_impact

# --- Orchestration guardrails ---
SEMPKG_AGENT_MAX_ITERATIONS=12
SEMPKG_AGENT_DEFAULT_QUERY_LIMIT=10
SEMPKG_AGENT_MAX_FINDINGS=12
# Log every LLM reasoning step + sempkg tool call/result (to the
# `sempkg_agent.trace` logger). Great for inspecting agent behaviour; off by default.
SEMPKG_AGENT_TRACE=0

# --- Server ---
SEMPKG_AGENT_HOST=0.0.0.0
SEMPKG_AGENT_PORT=8900
SEMPKG_AGENT_LOG_LEVEL=INFO
# Public URL advertised in the A2A AgentCard (must be reachable by callers).
SEMPKG_AGENT_PUBLIC_URL=http://localhost:8900
# Optional shared-secret bearer token gating inbound REST requests (empty = open).
# SEMPKG_AGENT_AUTH_TOKEN=change-me
